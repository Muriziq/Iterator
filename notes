function canvasSize() {
  const canvassRect = canvass.getBoundingClientRect();
  const screenLimit = {
    width: canvassRect.width - 50,
    height: canvassRect.height - 50,
  };

  // Update display fields
  width.value = changeValues(measurement.width);
  height.value = changeValues(measurement.height);

  let newWidth, newHeight;

  const isPortrait = canvasOrientation === "potrait";

  if (isPortrait) {
    if (measurement.height > measurement.width) {
      newWidth = (measurement.width / measurement.height) * screenLimit.height;
      newHeight = screenLimit.height;
    } else {
      newWidth = screenLimit.width;
      newHeight = (measurement.height / measurement.width) * screenLimit.width;
    }
  } else {
    if (measurement.height > measurement.width) {
      newHeight = (measurement.width / measurement.height) * screenLimit.width;
      newWidth = screenLimit.width;
    } else {
      newWidth = (measurement.height / measurement.width) * screenLimit.height;
      newHeight = screenLimit.height;
    }
  }

  // Only scale down if needed
  if (newWidth > measurement.width || newHeight > measurement.height) {
    newWidth = measurement.width;
    newHeight = measurement.height;
  }

  canvassDiv.style.width = `${newWidth}px`;
  canvassDiv.style.height = `${newHeight}px`;

  fitToPage();  // Optional: only needed if further fitting is still desired
  draw();       // Your drawing logic
}
