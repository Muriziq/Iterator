document.getElementById("delete").addEventListener("click", () => {
  if (selectedObj) {
    let index = objects.indexOf(selectedObj);
    objects.splice(index, 1);
    selectedObj = null;
    propertiesBar.innerHTML = "";
    requestDraw()
  }
});
