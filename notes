async function saveAsPDF() {
  const element = document.getElementById("generationArea");

  try {
    await new Promise((resolve) => setTimeout(resolve, 100));

    const dataUrl = await domtoimage.toPng(element);

    const { jsPDF } = window.jspdf;

    // Create a new jsPDF instance with specific page format and orientation
    // 'p' = portrait, 'l' = landscape
    // page format can be 'a4', 'letter', etc.
    const pdf = new jsPDF({
      orientation: "p",
      unit: "mm",
      format: "a4"
    });

    // Get page dimensions in mm
    const pdfWidth = pdf.internal.pageSize.getWidth();
    const pdfHeight = pdf.internal.pageSize.getHeight();

    const imgProps = pdf.getImageProperties(dataUrl);

    // Calculate height keeping aspect ratio
    const imgHeight = (imgProps.height * pdfWidth) / imgProps.width;

    // If image height is larger than PDF page height, you may want to scale it down
    const finalHeight = imgHeight > pdfHeight ? pdfHeight : imgHeight;

    // Add image to PDF, fit to width and adjust height
    pdf.addImage(dataUrl, "PNG", 0, 0, pdfWidth, finalHeight);

    pdf.save("content.pdf");
  } catch (error) {
    console.error("oops, something went wrong!", error);
  }
}
function getNewHeight(newWidth, olds) {
  const old = olds.getBoundingClientRect();
  const newHeight = (newWidth * old.height) / old.width;
  return newHeight;
}

function generateCard() {
  let iterationLength = 0;
  if (textBoxes.length > 0) {
    textBoxes.forEach((textbox) => {
      const textAreaLoad = textbox.textArea.split("\n");
      if (textAreaLoad.length > iterationLength) {
        iterationLength = textAreaLoad.length;
      }
    });

    for (let i = 0; i < iterationLength; i++) {
      const div = document.createElement("div");
      const img = document.createElement("img");
      img.src = canvas.toDataURL();
      div.style.position = "relative";
      div.style.backgroundColor = "lightblue";
      div.append(img);

      generationArea.append(div);
      div.style.width = "100%";
      div.style.height =
        getNewHeight(div.getBoundingClientRect().width, canvass) + "px";
      textBoxes.forEach((textbox) => {
        div.append(
          textbox.generateText(i, {
            width: div.getBoundingClientRect().width,
            height: div.getBoundingClientRect().height,
          })
        );
      });
    }
  }


  async function saveAsPDF() {
  const container = document.getElementById("generationArea");
  const divs = container.querySelectorAll(".a4-page"); // each child div is one A4 page

  try {
    const { jsPDF } = window.jspdf;
    const pdf = new jsPDF("p", "mm", "a4");

    for (let i = 0; i < divs.length; i++) {
      const div = divs[i];

      // Wait to ensure styles are applied
      await new Promise((resolve) => setTimeout(resolve, 100));

      // Convert div to PNG image
      const dataUrl = await domtoimage.toPng(div);

      // Calculate size to fit A4 dimensions
      const imgProps = pdf.getImageProperties(dataUrl);
      const pdfWidth = pdf.internal.pageSize.getWidth();
      const pdfHeight = (imgProps.height * pdfWidth) / imgProps.width;

      // Add image to PDF
      if (i > 0) pdf.addPage(); // Only add a page after the first
      pdf.addImage(dataUrl, "PNG", 0, 0, pdfWidth, pdfHeight);
    }

    pdf.save("multi-page.pdf");
  } catch (error) {
    console.error("oops, something went wrong!", error);
  }
}




async function saveAsPDF() {
  const container = document.getElementById("generationArea");
  const sections = container.querySelectorAll("section");

  const { jsPDF } = window.jspdf;
  const pdf = new jsPDF({
    orientation: "portrait",
    unit: "px", // Use pixels to match DOM dimensions
    format: [1, 1], // Temporary small size, will resize per page
  });

  for (let i = 0; i < sections.length; i++) {
    const section = sections[i];

    try {
      await new Promise((resolve) => setTimeout(resolve, 100)); // Wait for layout

      const dataUrl = await domtoimage.toPng(section);
      const imgProps = pdf.getImageProperties(dataUrl);

      const imgWidth = imgProps.width;
      const imgHeight = imgProps.height;

      // Resize the page to match the image
      if (i > 0) pdf.addPage([imgWidth, imgHeight]);
      else pdf.setPage(1); // Set page 1 size
      pdf.setPage(i + 1);

      pdf.addImage(dataUrl, "PNG", 0, 0, imgWidth, imgHeight);
    } catch (error) {
      console.error(`Error rendering section ${i + 1}`, error);
    }
  }

  pdf.save("content.pdf");
}



